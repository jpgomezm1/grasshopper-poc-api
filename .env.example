# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for Whisper transcription
OPENAI_API_KEY=sk-...

# Environment (development | production)
ENVIRONMENT=development

# CORS Origins (comma-separated for production)
CORS_ORIGINS=https://your-frontend.netlify.app,http://localhost:5173

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-key-change-this

# -----------------------------------------------------------------------------
# Storage (GH-S3-INFRA-04 · D-010 Supabase Storage)
# Leave empty in S3-S11 dev — storage_service.py falls back to in-memory stub.
# Real values land in S12 alongside Heroku/Netlify cutover.
# -----------------------------------------------------------------------------

# Backend choice: "supabase" | "stub" | "" (auto · uses supabase if SUPABASE_SERVICE_KEY is set)
STORAGE_BACKEND=

# Supabase project URL · format: https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase service_role key · server-side ONLY · never expose to FE
SUPABASE_SERVICE_KEY=

# Supabase Storage bucket · created in S12 (private bucket · signed URLs only)
SUPABASE_STORAGE_BUCKET=grasshopper-uploads
